{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "nome",
    "email",
    "password",
    "administrador",
    "_id"
  ],
  "properties": {
    "nome": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "password": {
      "type": "string"
    },
    "administrador": {
      "type": "string",
      "enum": [
        "true",
        "false"
      ]
    },
    "_id": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
